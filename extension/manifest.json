{
  "manifest_version": 3,
  "name": "HOOPIUM — Solana Token Scanner",
  "version": "1.0.0",
  "description": "Paste a Solana contract address and get an instant rug-risk report from your local HOOPIUM server.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "HOOPIUM scanner"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["contextMenus", "storage"],
  "host_permissions": ["http://localhost:5001/*", "http://127.0.0.1:5001/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
